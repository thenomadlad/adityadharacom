---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Card from "../components/card.svelte";
import LanguageIcon from "../components/language_icon.svelte";
import { SITE_DESCRIPTION } from "../consts";
import { load, type RepoDeets } from "../lib/github_repos";

let gh_data: {repos: RepoDeets[]} = {repos: []};
try {
  gh_data = await load();
} catch (e) {
  console.error("Failed to get github data", e);
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_DESCRIPTION} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto pt-24">
      <div class="flex">
        <div class="m-auto inline-grid gap-y-20 justify-center items-center">
          <div
            class="inline-grid xl:grid-cols-4 lg:grid-cols-3 grid-cols-2 gap-x-4 gap-y-4 mb-4"
          >
            {
              gh_data.repos.map((repo) => (
                <a class="block" href={repo.url}>
                  <Card heading={repo.name} date={repo.created_at}>
                    <LanguageIcon language={repo.language} />
                  </Card>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
